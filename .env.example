# App
# Production (Vercel): set to your canonical URL, e.g. https://portal.example.com
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME="Client Portal"

# Supabase (replace with real values from your Supabase project)
# For local development after `npm run supabase:start`, use:
# NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_URL=https://placeholder.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=placeholder_supabase_publishable_key
SUPABASE_SECRET_KEY=placeholder_supabase_secret_key

# Stripe (replace with real values from your Stripe dashboard)
STRIPE_SECRET_KEY=sk_test_placeholder_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_placeholder_stripe_webhook_secret
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_placeholder_stripe_publishable_key

# JustCall (replace with real API credentials)
JUSTCALL_API_KEY=placeholder_justcall_api_key
JUSTCALL_API_SECRET=placeholder_justcall_api_secret

# HubSpot (replace with real access token)
HUBSPOT_ACCESS_TOKEN=placeholder_hubspot_access_token
